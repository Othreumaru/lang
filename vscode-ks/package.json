{
  "name": "krzysztof-script",
  "displayName": "Krzysztof Script",
  "description": "Syntax highlighting for KS (Krzysztof Script)",
  "version": "0.1.0",
  "publisher": "lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ks",
        "aliases": [
          "Krzysztof Script",
          "ks"
        ],
        "extensions": [
          ".ks"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ks",
        "scopeName": "source.ks",
        "path": "./syntaxes/ks.tmLanguage.json"
      }
    ]
  }
}
