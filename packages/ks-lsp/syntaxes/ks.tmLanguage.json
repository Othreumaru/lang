{
  "name": "Krzysztof Script",
  "scopeName": "source.ks",
  "fileTypes": ["ks"],
  "patterns": [
    { "include": "#import-statement" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "import-statement": {
      "comment": "from \"module\" import { name1, name2 }",
      "match": "\\b(from)\\b(\\s*)(\"[^\"]*\"|'[^']*')(\\s*)(import)\\b",
      "captures": {
        "1": { "name": "keyword.control.import.ks" },
        "3": { "name": "string.quoted.double.ks" },
        "5": { "name": "keyword.control.import.ks" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ks",
          "match": "\\b(if|else|return)\\b"
        },
        {
          "name": "storage.type.ks",
          "match": "\\b(const|let)\\b"
        },
        {
          "name": "keyword.control.import.ks",
          "match": "\\b(from|import)\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.boolean.ks",
      "match": "\\b(true|false)\\b"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ks",
          "begin": "\"",
          "end": "\"",
          "patterns": []
        },
        {
          "name": "string.quoted.single.ks",
          "begin": "'",
          "end": "'",
          "patterns": []
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.ks",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.ks",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.ks",
          "match": "===|!==|>=|<=|(?<!=)>(?!=)|(?<!=)<(?!=)"
        },
        {
          "name": "keyword.operator.logical.ks",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment.ks",
          "match": "(?<![=!<>])=(?![=>])"
        },
        {
          "name": "keyword.operator.arithmetic.ks",
          "match": "[+\\-*\\/]"
        }
      ]
    },
    "function-call": {
      "comment": "Highlight identifiers immediately followed by (",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.ks" }
      }
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.parens.begin.ks", "match": "\\(" },
        { "name": "punctuation.section.parens.end.ks", "match": "\\)" },
        { "name": "punctuation.section.braces.begin.ks", "match": "\\{" },
        { "name": "punctuation.section.braces.end.ks", "match": "\\}" },
        { "name": "punctuation.separator.comma.ks", "match": "," },
        { "name": "punctuation.terminator.statement.ks", "match": ";" }
      ]
    }
  }
}
